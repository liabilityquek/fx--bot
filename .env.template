# FX Trading Bot - Environment Configuration Template
# Copy this file to .env and fill in your actual API keys

# ==========================================
# BROKER: OANDA Configuration
# ==========================================
# Get your API key from: https://www.oanda.com/account/tpa/personal_token
OANDA_API_KEY=your_oanda_api_key_here
OANDA_ACCOUNT_ID=your_account_id_here
OANDA_ENVIRONMENT=practice  # practice or live (USE PRACTICE FOR PAPER TRADING!)

# ==========================================
# DATA SOURCES (Phase 6)
# ==========================================
# yfinance: Historical OHLC data (NO API KEY REQUIRED)
# - Forex pairs supported (e.g., EURUSD=X)
# - Free and unlimited

# investpy: Economic calendar from Investing.com (NO API KEY REQUIRED)
# - pip install investpy
# - Free and reliable

# NewsAPI.org: World news for sentiment analysis
# Free tier: 100 calls/day
# Get key from: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# ==========================================
# LLM STRATEGIST (Phase 6)
# ==========================================
# Anthropic Claude API for LLM-powered strategy generation
# Get key from: https://console.anthropic.com/settings/keys
# Leave empty to use fallback strategy generator
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (default: claude-opus-4-5-20250220)
# Options: claude-opus-4-5-20250220, claude-sonnet-4-20250514, claude-3-5-haiku-20241022
LLM_MODEL=claude-opus-4-5-20250220

# Strategy validity in hours (default: 12)
# How long before strategy needs regeneration
STRATEGY_VALIDITY_HOURS=12

# ==========================================
# TRADING PARAMETERS
# ==========================================
TRADING_PAIRS=EUR_USD,GBP_USD,USD_JPY,USD_CHF,AUD_USD
TIMEFRAME=H1  # 1-hour candles
INITIAL_CAPITAL=10000  # Starting capital in account currency
MAX_LEVERAGE=30  # Maximum leverage (OANDA offers up to 50:1 for retail)

# Risk Management
MAX_RISK_PER_TRADE=0.02  # 2% max risk per trade
MAX_TOTAL_EXPOSURE=0.10  # 10% max aggregate exposure across all pairs
DEFAULT_STOP_LOSS_PIPS=50  # Default stop loss in pips
DEFAULT_TAKE_PROFIT_RATIO=2.0  # Risk/Reward ratio (2:1)

# ==========================================
# MONITORING & ALERTS (Telegram)
# ==========================================
# Enable/disable alerts
ALERT_ENABLED=true

# Telegram Bot Configuration
# 1. Create a bot via @BotFather on Telegram
# 2. Get your chat ID via @userinfobot or @getidsbot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ==========================================
# LOGGING
# ==========================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_TO_FILE=true
LOG_FILE_PATH=logs/trading_bot.log

# ==========================================
# ECONOMIC CALENDAR FILTERING
# ==========================================
# Suspend trading X minutes before high-impact news
NEWS_SUSPEND_BEFORE_MINUTES=30
# Resume trading X minutes after news event
NEWS_RESUME_AFTER_MINUTES=15
# High-impact event keywords (comma-separated)
HIGH_IMPACT_EVENTS=NFP,FOMC,GDP,CPI,Interest Rate,Central Bank

# ==========================================
# SYSTEM
# ==========================================
# Enable paper trading mode (always keep true until fully tested!)
PAPER_TRADING_MODE=true
# Data cache duration in hours
DATA_CACHE_HOURS=24
